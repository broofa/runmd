{
  "name": "runmd",
  "author": {
    "name": "Robert Kieffer",
    "email": "robert@broofa.com"
  },
  "version": "2.1.0",
  "type": "module",
  "bin": {
    "runmd": "./dist/cli.js"
  },
  "description": "Execute and update code blocks embedded in Markdown files",
  "keywords": [
    "markdown",
    "readme"
  ],
  "files": [
    "dist/**",
    "!dist/**/*.test.*",
    "!dist/samples/**"
  ],
  "types": "./dist/RunmdDoc.d.ts",
  "license": "MIT",
  "homepage": "https://github.com/broofa/runmd",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/broofa/runmd.git"
  },
  "dependencies": {
    "commander": "14.0.3"
  },
  "peerDependencies": {
    "prettier": "^3"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "25.6.0",
    "commitlint": "20.5.2",
    "lefthook": "2.1.6",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc --watch -p tsconfig.json",
    "build:test": "bash ./bin/build-test.sh",
    "prepare": "lefthook install",
    "docs": "node ./dist/cli.js README_js.md --output README.md",
    "docs:test": "npm run docs -- --check",
    "lint": "biome check --write",
    "lint:test": "biome check",
    "unit:test": "node --test dist/**/*.test.js",
    "pretest": "npm run build",
    "test": "run-p docs:test lint:test unit:test build:test"
  }
}
