{
  "name": "runmd",
  "author": {
    "name": "Robert Kieffer",
    "email": "robert@broofa.com"
  },
  "version": "2.1.0",
  "type": "module",
  "bin": {
    "runmd": "./src/cli.ts"
  },
  "description": "Execute and update code blocks embedded in Markdown files",
  "keywords": [
    "markdown",
    "readme"
  ],
  "files": [
    "src/**",
    "!src/**/*.test.ts"
  ],
  "license": "MIT",
  "homepage": "https://github.com/broofa/runmd",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/broofa/runmd.git"
  },
  "dependencies": {
    "commander": "14.0.3",
    "tsx": "4.21.0"
  },
  "peerDependencies": {
    "prettier": "^3"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "25.6.0",
    "commitlint": "20.5.2",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "scripts": {
    "prepare": "lefthook install",
    "docs": "./src/cli.ts README_js.md --output README.md",
    "docs:test": "npm run docs -- --check",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test:unit": "node --test src/**/*.test.js src/**/*.test.ts",
    "test": "npm run docs:test && npm run lint && npm run test:unit"
  }
}
